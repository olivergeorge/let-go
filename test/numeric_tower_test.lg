;; Numeric tower tests: Float type, cross-type arithmetic, comparisons
(ns test.numeric-tower-test
  (:require [test :refer :all]))

(deftest float-literals
  (testing "float literal parsing"
    (is (= 3.14 3.14))
    (is (= -0.5 -0.5))
    (is (float? 3.14))
    (is (float? -0.5))
    (is (float? 1e10))
    (is (not (float? 42)))))

(deftest cross-type-arithmetic
  (testing "int + float promotes to float"
    (is (= 3.5 (+ 1 2.5)))
    (is (float? (+ 1 2.5)))
    (is (= 4.5 (* 3 1.5)))
    (is (float? (* 3 1.5))))

  (testing "float + int promotes to float"
    (is (= 3.5 (+ 2.5 1)))
    (is (float? (+ 2.5 1))))

  (testing "float + float stays float"
    (is (= 3.0 (+ 1.5 1.5)))
    (is (float? (+ 1.5 1.5))))

  (testing "int + int stays int"
    (is (= 3 (+ 1 2)))
    (is (int? (+ 1 2)))))

(deftest division-behavior
  (testing "exact int division returns int"
    (is (= 5 (/ 10 2)))
    (is (int? (/ 10 2))))

  (testing "non-exact int division returns ratio"
    (is (ratio? (/ 10 3))))

  (testing "division involving float returns float"
    (is (float? (/ 10.0 3)))
    (is (float? (/ 10 3.0))))

  (testing "unary division returns reciprocal"
    (is (= 1/2 (/ 2)))
    (is (= 0.5 (/ 2.0)))
    (is (= 2 (/ 1/2)))))

(deftest cross-type-comparison
  (testing "comparing int and float"
    (is (> 3.14 3))
    (is (< 3 3.14))
    (is (== 1 1.0))
    (is (== 1.0 1))
    (is (not (= 1 1.0)))
    (is (not (= 1.0 1)))
    (is (not (= 1 1.5)))))

(deftest coercion-functions
  (testing "float coercion"
    (is (= 42.0 (float 42)))
    (is (float? (float 42)))
    (is (= 0.0 (float 4.9E-324)))
    (is (= 4.9E-324 (double 4.9E-324)))
    (is (try
          (float 1.7976931348623157E308)
          false
          (catch e true))))

  (testing "int coercion truncates"
    (is (= 3 (int 3.7)))
    (is (int? (int 3.7)))
    (is (= 3 (int 3.2))))

  (testing "int coercion checks 32-bit bounds"
    (is (= 2147483647 (int 2147483647)))
    (is (= -2147483648 (int -2147483648)))
    (is (try
          (int 2147483648)
          false
          (catch e true)))
    (is (try
          (int -2147483649)
          false
          (catch e true)))))

(deftest long-coercion
  (testing "long coercion accepts full 64-bit range"
    (is (= 9223372036854775807 (long 9223372036854775807)))
    (is (= -9223372036854775808 (long -9223372036854775808)))
    (is (= -4611686018427387904 (long (/ -9223372036854775808 2))))
    (is (try
          (long 9223372036854775808N)
          false
          (catch e true)))))

(deftest numeric-predicates
  (testing "number? recognizes both int and float"
    (is (number? 42))
    (is (number? 3.14))
    (is (not (number? "42")))
    (is (not (number? :foo))))

  (testing "num preserves nil"
    (is (nil? (num nil))))

  (testing "float? predicate"
    (is (float? 3.14))
    (is (float? (float 3.14)))
    (is (not (double? (float 3.14))))
    (is (double? (double 3.14)))
    (is (not (float? 42)))
    (is (not (float? "3.14"))))

  (testing "int? predicate"
    (is (int? 42))
    (is (not (int? 3.14)))
    (is (not (int? "42")))))

(deftest multi-arity-comparisons
  (testing "< with multiple args"
    (is (< 1 2 3))
    (is (< 1 2 3 4 5))
    (is (not (< 1 3 2))))

  (testing "> with multiple args"
    (is (> 3 2 1))
    (is (> 5 4 3 2 1))
    (is (not (> 3 1 2)))))

(deftest checked-int-arithmetic
  (testing "integer overflow throws"
    (let [max-int 9223372036854775807
          min-int -9223372036854775808]
      (is (try (+ max-int 1) false (catch e true)))
      (is (try (+ min-int -1) false (catch e true)))
      (is (try (- min-int 1) false (catch e true)))
      (is (try (- max-int -1) false (catch e true)))
      (is (try (* min-int -1) false (catch e true)))
      (is (try (* -1 min-int) false (catch e true)))
      (is (try (inc max-int) false (catch e true)))
      (is (try (dec min-int) false (catch e true)))
      (is (try (inc nil) false (catch e true)))
      (is (try (dec nil) false (catch e true))))))

(deftest apostrophe-overflow-promotion
  (testing "+' promotes at int64 boundary"
    (is (= 9223372036854775808N (+' 9223372036854775807 1)))
    (is (= -9223372036854775809N (+' -9223372036854775808 -1)))
    (is (bigint? (+' 9223372036854775807 1)))
    (is (bigint? (+' -9223372036854775808 -1))))

  (testing "-' promotes at int64 boundary"
    (is (= -9223372036854775809N (-' -9223372036854775808 1)))
    (is (= 9223372036854775808N (-' 0 -9223372036854775808)))
    (is (bigint? (-' -9223372036854775808 1))))

  (testing "*' promotes at int64 boundary"
    (is (= 18446744073709551614N (*' 9223372036854775807 2)))
    (is (= 9223372036854775808N (*' -9223372036854775808 -1)))
    (is (bigint? (*' 9223372036854775807 2))))

  (testing "apostrophe ops stay Int when no overflow"
    (is (= 3 (+' 1 2)))
    (is (= -1 (-' 1 2)))
    (is (= 6 (*' 2 3)))
    (is (int? (+' 1 2)))
    (is (int? (*' 2 3))))

  (testing "BigInt identity preserved through unary -'"
    (is (= -1N (-' 1N)))
    (is (= 1N (-' -1N)))
    (is (bigint? (-' 1N)))
    (is (bigint? (-' -1N))))

  (testing "BigInt identity preserved through binary ops with BigInt arg"
    (is (bigint? (+' 1 1N)))
    (is (bigint? (-' 1N 1)))
    (is (bigint? (*' 1N 1))))

  (testing "variadic 0-arity matches Clojure"
    (is (= 0 (+')))
    (is (= 1 (*'))))

  (testing "variadic chain across overflow boundary"
    ;; First mul stays in int64, second overflows
    (is (= 18446744073709551614N (*' 9223372036854775807 1 2)))
    (is (bigint? (*' 9223372036854775807 1 2)))
    ;; BigInt threaded through middle
    (is (= 6N (+' 1 2N 3)))
    (is (bigint? (+' 1 2N 3))))

  (testing "inc'/dec' compose through +'/-'"
    (is (= 9223372036854775808N (inc' 9223372036854775807)))
    (is (= -9223372036854775809N (dec' -9223372036854775808)))
    (is (bigint? (inc' 9223372036854775807)))
    (is (bigint? (dec' -9223372036854775808))))

  (testing "unary -' on Long/MIN_VALUE promotes (eval-level regression net)"
    ;; Go-level TestNumNegP_MinInt covers this, but a future mis-wire of
    ;; NumNegP via lang.go would slip past every other .lg test.
    (is (bigint? (-' -9223372036854775808)))
    (is (= 9223372036854775808N (-' -9223372036854775808))))

  (testing "-' stays Int when result still fits (no over-eager promotion)"
    ;; Mirrors Clojure JVM test_clojure/numbers.clj's
    ;; test-arbitrary-precision-subtract — asserts -' doesn't over-promote.
    (is (int? (-' 0 -9223372036854775807)))
    (is (= 9223372036854775807 (-' 0 -9223372036854775807))))

  (testing "+' variadic mid-chain overflow"
    ;; First reduce stays Int (MaxLong + 1 would overflow → BigInt, second
    ;; reduce adds 1 to BigInt → BigInt). Asserts the reducer correctly
    ;; threads the BigInt through subsequent steps.
    (is (= 9223372036854775809N (+' 9223372036854775807 1 1)))
    (is (bigint? (+' 9223372036854775807 1 1))))

  (testing "invalid binary inputs error"
    (is (try (+' 1 nil) false (catch _ true)))
    (is (try (-' 1 nil) false (catch _ true)))
    (is (try (*' nil 1) false (catch _ true))))

  (testing "unary +' and *' pass through non-numbers (matches +/*)"
    ;; Documents existing let-go semantics: `(+ x)` and `(* x)` return x
    ;; unchanged for any x. The apostrophe variants match. Clojure JVM
    ;; would coerce/validate here; let-go does not. Out of scope for
    ;; TASK-7 since the same is true of `+`/`*`.
    (is (= nil (+' nil)))
    (is (= nil (*' nil)))
    (is (= "x" (+' "x")))
    (is (= "x" (*' "x")))
    ;; Unary -' DOES go through NumNegP and will error on non-numbers.
    (is (try (-' nil) false (catch _ true)))
    (is (try (-' "x") false (catch _ true)))))
