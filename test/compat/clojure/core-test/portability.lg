(ns clojure.core-test.portability
  (:require [test :refer :all]))

;; when-var-exists: In let-go we don't have compile-time resolve,
;; so we just always emit the body. Tests for missing vars will fail
;; at compile time and the Go runner treats those as SKIPs.
(defmacro when-var-exists [var-sym & body]
  `(do ~@body))

;; thrown?: portable exception assertion.
;; Used as (is (p/thrown? expr)) — must return truthy on exception.
;; Note: let-go catch syntax is (catch bindSym body...) not (catch Class bindSym body...)
(defmacro thrown? [& body]
  `(try
     (do ~@body false)
     (catch _# true)))

;; Portability constants used by many test files
(def max-int 9007199254740991)       ;; 2^53-1 (JS safe integer max, good enough)
(def min-int -9007199254740991)
(def max-double 1.7976931348623157E308)
(def min-double 4.9E-324)
(def all-ones-int -1)

;; big-int? — let-go doesn't have BigInteger, so always false for regular ints
(defn big-int? [n]
  (and (integer? n) (not (int? n))))

;; Java class name aliases used by upstream tests
(def clojure.lang.BigInt (type 1N))
(def clojure.lang.Ratio (type 1/2))
(def clojure.lang.BigDecimal (type 1M))

;; MapEntry/create constructs a [k v] pair — our PersistentMap already uses vectors
;; for entries so a plain vector satisfies (instance? ...) via vector equality checks.
(ns clojure.lang.MapEntry)
(defn create [k v] (first {k v}))

;; Best-effort stubs for Clojure APIs that let-go doesn't implement. These
;; let more test files compile; tests that exercise real behavior will fail
;; at runtime but that's tracked via knownFailing.
(in-ns 'core)
(defn ^:private _compat-unsupported [op] (fn [& _] (throw (str op " not supported in let-go"))))
(def ref atom)                                  ; refs → atoms (no STM)
;; agents: stubbed as atoms with synchronous `send`. No real concurrency,
;; but watch/action errors are retained so agent-error/restart-agent flows work.
(def ^:private *agent-errors* (atom {}))
(def agent atom)
(def send (fn [a f & args]
            (try
              (apply swap! a f args)
              (catch e
                (swap! *agent-errors* assoc a e)))
            a))
(def send-off send)
(def await (fn [& _] nil))
(def await-for (fn [_ & _] true))
(def agent-error (fn [a] (get @*agent-errors* a)))
(def restart-agent (fn [a v & _]
                     (swap! *agent-errors* dissoc a)
                     (reset! a v)
                     a))
(def set-error-handler! (fn [_ _] nil))
(def set-error-mode! (fn [_ _] nil))
(def error-handler (fn [_] nil))
(def error-mode (fn [_] :continue))
(def shutdown-agents (fn [] nil))
(def release-pending-sends (fn [] 0))
(def get-validator clojure.core/get-validator)
(def future-cancel (fn [_] false))
(def bound-fn* identity)
(defmacro bound-fn [& body] `(fn ~@body))
(defmacro with-precision [_ & body] `(do ~@body))
;; dosync — we don't have STM. Single-threaded evaluation of the body
;; behaves atomically with respect to other let-go code.
(defmacro dosync [& body] `(do ~@body))
;; ref operations — treat refs as atoms, no coordination
(def ref-set (fn [r v] (reset! r v)))
(def alter (fn [r f & args] (apply swap! r f args)))
(def commute alter)
(def ensure deref)
;; tap>, add-tap, remove-tap are now built-in.
;; Java class-name aliases used in hierarchy tests
(def String (type ""))
(def clojure.lang.PersistentHashSet (type #{}))
(def clojure.lang.Associative 'clojure.lang.Associative)
(def clojure.lang.Counted :clojure-lang-Counted-stub)
(def clojure.lang.Indexed :clojure-lang-Indexed-stub)
(def clojure.lang.Seqable :clojure-lang-Seqable-stub)
(def clojure.lang.IPersistentCollection :clojure-lang-IPersistentCollection-stub)
;; Rounding enum sentinels for with-precision (which is a no-op anyway)
(def UP :up)
(def DOWN :down)
(def HALF_UP :half-up)
(def HALF_DOWN :half-down)
(def HALF_EVEN :half-even)
(def CEILING :ceiling)
(def FLOOR :floor)
(def UNNECESSARY :unnecessary)
(def clojure.lang.IPending (type (promise)))    ; let-go IPending ≡ Promise
(in-ns 'clojure.core-test.portability)
